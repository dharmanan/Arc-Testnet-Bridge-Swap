# Sepolia Network
VITE_SEPOLIA_RPC=https://ethereum-sepolia-rpc.publicnode.com

# Arc Testnet Network
VITE_ARC_TESTNET_RPC=https://rpc.testnet.arc.network

# WalletConnect (optional, recommended for mobile wallets)
VITE_WALLETCONNECT_PROJECT_ID=

# Uniswap V2
VITE_UNISWAP_ROUTER=0x68b3465833fb72B5A828cCEEAa5BE01d33e3B3d8
VITE_UNISWAP_FACTORY=0x1F98431c8aD98523631AE4a59f267346ea3113F

# Tokens
VITE_WETH=0xfFf9976782d46CC05630D06953f7751f7DA666DC
VITE_USDC=0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238

# Circle Bridge Kit (optional)
# Safe to expose in the browser only if the client SDK explicitly requires it.
VITE_CIRCLE_APP_ID=your_circle_app_id
# Do not put Circle API secrets in Vite env vars. Keep them in a backend/runtime env.
